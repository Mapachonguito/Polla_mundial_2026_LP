    };

    let authMode = 'login';
    window.setMode = function(m) { 
      authMode = m;
      // Limpiar campos
      document.getElementById('user').value = '';
      document.getElementById('pw').value = '';
      document.getElementById('name').value = '';
      document.getElementById('email').value = '';
      document.getElementById('pw_reg').value = '';
      
      // Mostrar/ocultar campos
      document.getElementById('loginFields')?.classList.toggle('hidden', m==='reg');
      document.getElementById('regFields')?.classList.toggle('hidden', m==='login');
      
      // Cambiar botón activo
      document.querySelectorAll('.login-buttons button').forEach((btn, i) => {
        btn.classList.toggle('active', (i === 0 && m === 'login') || (i === 1 && m === 'reg'));
      });
    };
    
    window.doAuth = async function() {
      try {
        // Validar que authMode sea válido
        if(!['login', 'reg'].includes(authMode)) {
          return alert('Error: Modo de autenticación inválido. Recarga la página.');
        }
        
        if(authMode === 'login') {
          const userField = document.getElementById('user');
          const pwField = document.getElementById('pw');
          
          if(!userField || !pwField) {
            console.error('Campos no encontrados', { userField, pwField });
            return alert('Error: Los campos de login no están visibles. Intenta refrescar la página.');
          }
          
          const email = (userField.value || '').toLowerCase().trim();
          const pw = (pwField.value || '').trim();
          
          console.log('Login - Valores leídos:', { email, pw, emailLength: email.length, pwLength: pw.length });
          
          if(!email || !pw) {
            return alert('Llena todos los campos.\n\nCampo correo: ' + (email ? '✓' : '✗') + '\nCampo contraseña: ' + (pw ? '✓' : '✗'));
          }
          
          // Validar email
          const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
          if(!emailRegex.test(email)) return alert('Por favor ingresa un email válido');
          
          const u = await sb.from('polla_trabajo_users').select('*').eq('email', email);
          console.log('Login - Usuario buscado por email:', email, 'Resultado:', u);
          
          if(!u.data?.length) return alert(`No encontramos una cuenta con el email "${email}". ¿Está seguro que se registró?`);
          if(u.data[0].pw !== hashPw(pw)) return alert('Contraseña incorrecta');
          
          const userId = u.data[0].id; // El id es el nombre de usuario
          state.users[userId] = u.data[0];
          state.me = userId;
          localStorage.setItem('polla_user', userId);
        } else {
          const nameField = document.getElementById('name');
          const emailField = document.getElementById('email');
          const pwRegField = document.getElementById('pw_reg');
          
          if(!nameField || !emailField || !pwRegField) {
            return alert('Error: Los campos no están visibles. Intenta de nuevo.');
          }
          
          const name = (nameField.value || '').trim();
          const email = (emailField.value || '').trim();
          const pw = (pwRegField.value || '').trim();
          
          if(!name || !email || !pw) {
            return alert('❌ Por favor completa todos los campos:\n\n' +
              'Nombre: ' + (name ? '✓' : '✗') + '\n' +
              'Correo: ' + (email ? '✓' : '✗') + '\n' +
              'Contraseña: ' + (pw ? '✓' : '✗'));
          }
          
          // Validar email básico
          const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
          if(!emailRegex.test(email)) return alert('Por favor ingresa un email válido');
          
          // Generar usuario automático basado en nombre (con espacios permitidos, minúsculas)
          const user = name.toLowerCase().trim();
          
          console.log('Registro - Nombre:', name, 'Email:', email, 'Usuario generado:', user);
          
          // Verificar que no exista usuario
          const exists = await sb.from('polla_trabajo_users').select('*').eq('id', user);
          if(exists.data?.length) return alert('Este nombre ya está registrado. Usa otro nombre.');
          
          // Verificar que no exista email
          const existsEmail = await sb.from('polla_trabajo_users').select('*').eq('email', email);
          if(existsEmail.data?.length) return alert('Este email ya está registrado.');
          
          const result = await sb.from('polla_trabajo_users').insert([{ id: user, displayname: name, email: email, pw: hashPw(pw), pwd: pw, role: 'participant', paid: false }]);
          console.log('Registro - Resultado:', result);
          
          if(result.error) {
            alert('Error al registrar: ' + result.error.message);
            return;
          }
          
          state.users[user] = { id: user, displayname: name, email: email, pw: hashPw(pw), pwd: pw, role: 'participant', paid: false };
          state.me = user;
          localStorage.setItem('polla_user', user);
          alert('✓ Registrado correctamente como: ' + user);
        }
        render();
      } catch(e) {
        console.error('Error en doAuth:', e);
        alert('Error: ' + e.message);
      }
    };

    window.doLogout = function() { 
      state.me = null; 
      state.tab = 'partidos'; 
      state.selectedDay = null; 
      state.pendingSaves = {}; 
      localStorage.removeItem('polla_user');
      render(); 
    };
    
    window.reiniciarPolla = async function() {
      if(!confirm('⚠️ ¿ESTÁS SEGURO?\n\nEsto borrará TODA la polla:\n- Todos los usuarios\n- Todos los partidos\n- Todas las apuestas\n- Todo el podio\n\nNo se puede deshacer.')) return;
      
      try {
        console.log('🔄 Reiniciando polla...');
        
        // Borrar en orden inverso (respetando foreign keys)
        await sb.from('polla_trabajo_podium').delete().gte('id', 0);
        console.log('✓ Podium eliminado');
        
        await sb.from('polla_trabajo_predictions').delete().gte('id', 0);
        console.log('✓ Predictions eliminado');
        
        await sb.from('polla_trabajo_matches').delete().neq('id', '');
        console.log('✓ Matches eliminado');
        
        await sb.from('polla_trabajo_users').delete().neq('id', '');
        console.log('✓ Users eliminado');
        
        await sb.from('polla_trabajo_config').delete().neq('id', '');
        console.log('✓ Config eliminado');
        
        alert('✅ Polla completamente reiniciada. Ahora puedes crear una nueva.');
        doLogout();
      } catch(e) {
        console.error('Error reiniciando:', e);
        alert('❌ Error: ' + e.message);
      }
    };
    
    window.showRecoverPassword = async function() {
      const email = prompt('Ingresa tu correo para recuperar tu contraseña:');
      if(!email) return;
      
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if(!emailRegex.test(email)) return alert('Email inválido');
      
      try {
        const result = await sb.from('polla_trabajo_users').select('id, displayname, pwd').eq('email', email);
        
        if(!result.data?.length) {
          return alert('No encontramos un usuario con ese email');
        }
        
        const user = result.data[0];
        alert(`✅ Recuperación de contraseña\n\nUsuario: ${user.id}\nContraseña: ${user.pwd}`);
      } catch(e) {
        console.error('Error recuperando contraseña:', e);
        alert('Error: ' + e.message);
      }
    };
    window.setTab = function(t) { 
      state.tab = t; 
      state.selectedDay = null; 
      localStorage.setItem('polla_tab', t);
      render(); 
    };
    
    // Swipe detection
    let touchStartX = 0;
    let touchEndX = 0;
    document.addEventListener('touchstart', e => {
      touchStartX = e.changedTouches[0].screenX;
    }, false);
    document.addEventListener('touchend', e => {
      touchEndX = e.changedTouches[0].screenX;
      const tabs = ['partidos', 'resumen', 'tabla'];
      if(state.me && state.users[state.me]?.role === 'admin') tabs.push('admin');
      const currentIdx = tabs.indexOf(state.tab);
      const diff = touchStartX - touchEndX;
      if(Math.abs(diff) > 50) { // al menos 50px de desliz
        if(diff > 0 && currentIdx < tabs.length - 1) setTab(tabs[currentIdx + 1]); // izquierda
        if(diff < 0 && currentIdx > 0) setTab(tabs[currentIdx - 1]); // derecha
      }
    }, false);
    window.filterDay = function(d) { state.selectedDay = d === '' ? null : d; render(); };
    
    window.deleteMatch = async function(mid) {
      try {
        await sb.from('polla_trabajo_matches').delete().eq('id', mid);
        state.matches = state.matches.filter(m => m.id !== mid);
        Object.keys(state.preds).forEach(k => {
          if(k.endsWith('::' + mid)) delete state.preds[k];
        });
        alert('✓ Partido eliminado');
        render();
      } catch(e) {
        console.error(e);
        alert('Error al eliminar');
      }
    };
    
    window.saveAllPreds = async function() {
      const allMatches = state.matches;
      let saved = 0;
      
      for(const m of open) {
        const h = document.getElementById(`h_${m.id}`)?.value;
        const a = document.getElementById(`a_${m.id}`)?.value;
        if(h && a) {
          const exist = await sb.from('polla_trabajo_predictions').select('*').eq('userId', state.me).eq('matchId', m.id);
          const key = state.me + '::' + m.id;
          
          if(exist.data?.length) {
            await sb.from('polla_trabajo_predictions').update({ homescore: +h, awayscore: +a }).eq('id', exist.data[0].id);
          } else {
            await sb.from('polla_trabajo_predictions').insert([{ id: Date.now() + saved + '', userId: state.me, matchId: m.id, homescore: +h, awayscore: +a }]);
          }
          
          state.preds[key] = { home: +h, away: +a };
          saved++;
        }
      }
      
      state.pendingSaves = {};
      alert(`✓ ${saved} pronóstico(s) guardado(s)`);
      render();
    };

    window.savePodium = function() {
      const first = document.getElementById('first').value;
      const second = document.getElementById('second').value;
      const third = document.getElementById('third').value;
      state.podium[state.me] = { first, second, third };
      alert('✓ Podio guardado');
      render();
    };

    window.togglePaid = async function(uid) {
      const u = state.users[uid];
      u.paid = !u.paid;
      await sb.from('polla_trabajo_users').update({ paid: u.paid }).eq('id', uid);
      render();
    };

    window.showPassword = function(uid) {
      const u = state.users[uid];
      const pwHashed = u.pw;
      // Como la contraseña está hasheada, no podemos recuperarla
      // Pero podemos permitir al admin resetear a una nueva
      const newPw = prompt(`Usuario: ${uid}\n\nLa contraseña actual está hasheada.\n\nIngresa una nueva contraseña para resetear (o deja vacío para cancelar):`);
      if(newPw === null || newPw === '') return;
      if(newPw.length < 3) return alert('La contraseña debe tener al menos 3 caracteres');
      
      u.pw = hashPw(newPw);
      sb.from('polla_trabajo_users').update({ pw: u.pw }).eq('id', uid);
      alert(`✓ Contraseña de ${u.displayname} reseteada a: "${newPw}"`);
    };

    window.deleteParticipant = async function(uid) {
      const userName = state.users[uid].displayname;
      if(!confirm(`¿Eliminar a ${userName}? Podrá volver a registrarse si lo desea.`)) return;
      try {
        // Primero eliminar predicciones
        await sb.from('polla_trabajo_predictions').delete().eq('userid', uid);
        // Luego eliminar usuario
        await sb.from('polla_trabajo_users').delete().eq('id', uid);
        delete state.users[uid];
        Object.keys(state.preds).forEach(k => {
          if(k.startsWith(uid + '::')) delete state.preds[k];
        });
        alert(`✓ ${userName} eliminado correctamente`);
        render();
      } catch(e) {
        console.error('Error eliminando participante:', e);
        alert('Error al eliminar: ' + e.message);
      }
    };

    window.saveAllMatches = async function() {
      let saved = 0;
      for(const m of state.matches) {
        const h = document.getElementById(`res_h_${m.id}`)?.value;
        const a = document.getElementById(`res_a_${m.id}`)?.value;
        const fin = document.getElementById(`fin_${m.id}`)?.checked;
        
        if(h !== undefined || a !== undefined || fin !== undefined) {
          m.homescore = h;
          m.awayscore = a;
          m.finished = fin;
          
          await sb.from('polla_trabajo_matches').update({ homescore: h, awayscore: a, finished: fin }).eq('id', m.id);
          saved++;
        }
      }
      alert(`✓ ${saved} resultado(s) guardado(s)`);
      render();
    };

