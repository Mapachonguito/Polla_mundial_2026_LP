    .tab-btn { flex: 1; min-width: 90px; background: #1C2438; color: var(--muted); border: 1px solid var(--line); padding: 10px; border-radius: 8px; cursor: pointer; font-weight: 700; font-size: 12px; }
    .tab-btn.active { background: var(--lime); color: var(--bg); }
    .hidden { display: none; }
    .badge { background: rgba(201,255,61,.15); color: var(--lime); padding: 3px 9px; border-radius: 999px; font-size: 11px; font-weight: 700; display: inline-block; margin-right: 6px; }
    .match { background: #0F1422; border: 1px solid #1C2438; border-radius: 8px; padding: 12px; margin-bottom: 8px; }
    .match-header { font-weight: 700; margin-bottom: 4px; font-size: 14px; }
    .match-date { font-size: 11px; color: var(--muted); margin-bottom: 8px; }
    .match-inputs { display: flex; gap: 6px; align-items: center; margin-top: 8px; }
    .match-inputs input { margin: 0; width: 50px; text-align: center; padding: 8px 0; }
    table { width: 100%; border-collapse: collapse; }
    table td { padding: 10px; border-bottom: 1px solid var(--line); font-size: 13px; }
    table th { background: #0F1422; padding: 10px; text-align: left; font-weight: 700; font-size: 13px; }
    hr { border: none; border-top: 1px solid var(--line); margin: 12px 0; }
    .pool-info { background: linear-gradient(135deg, #15203a, #151B2C); border: 1px solid var(--line); border-radius: 12px; padding: 14px; margin-bottom: 12px; }
    .pool-amount { font-size: 32px; color: var(--lime); font-weight: 700; margin-top: 4px; }
    .prize-chip { background: var(--surface); border: 1px solid var(--line); border-radius: 8px; padding: 8px 10px; flex: 1; font-size: 11px; margin-right: 8px; margin-bottom: 8px; }
    .prize-chip .label { color: var(--muted); font-weight: 700; font-size: 10px; }
    .prize-chip .amount { color: var(--lime); font-weight: 700; margin-top: 3px; }
    .leader-row { background: var(--surface); border: 1px solid var(--line); border-radius: 8px; padding: 12px; margin-bottom: 8px; display: flex; align-items: center; gap: 12px; }
    .leader-pos { font-size: 22px; font-weight: 700; width: 30px; }
    .leader-info { flex: 1; min-width: 0; }
    .leader-name { font-weight: 700; margin-bottom: 4px; font-size: 14px; }
    .leader-stats { font-size: 11px; color: var(--muted); }
    .leader-prize { font-size: 14px; color: var(--lime); font-weight: 700; text-align: right; }
    .bottom-nav { position: fixed; bottom: 0; left: 0; right: 0; background: rgba(10,13,22,.95); border-top: 1px solid var(--line); display: flex; justify-content: center; gap: 4px; padding: 8px; backdrop-filter: blur(8px); z-index: 50; flex-wrap: wrap; }
    .nav-btn { background: none; color: var(--muted); border: none; padding: 6px 14px; font-size: 11px; font-weight: 700; cursor: pointer; flex: 1; min-width: 80px; }
    .nav-btn.active { color: var(--lime); }
    #content { padding-bottom: 100px; }
    .admin-section { background: #0F1422; border: 1px solid var(--line); border-radius: 8px; padding: 12px; margin-bottom: 12px; }
    .admin-section h3 { color: var(--lime); font-size: 14px; margin-bottom: 10px; }
    .day-filter { display: flex; gap: 8px; margin-bottom: 12px; flex-wrap: wrap; overflow-x: auto; }
    .day-btn { background: #1C2438; color: var(--muted); border: 1px solid var(--line); padding: 8px 12px; border-radius: 8px; cursor: pointer; font-size: 12px; font-weight: 700; white-space: nowrap; }
    .day-btn.active { background: var(--lime); color: var(--bg); }
    .login-container { display: flex; flex-direction: column; gap: 10px; }
    .login-buttons { display: flex; gap: 10px; }
    .login-buttons button { flex: 1; background: #1C2438; color: var(--text); padding: 12px; }
    .login-buttons button.active { background: var(--lime); color: var(--bg); }
    .save-all-btn { position: fixed; bottom: 70px; left: 50%; transform: translateX(-50%); background: var(--lime); color: var(--bg); border: none; padding: 12px 30px; border-radius: 8px; font-weight: 700; cursor: pointer; z-index: 40; box-shadow: 0 4px 12px rgba(201,255,61,.3); }
    .save-all-btn:hover { opacity: 0.9; }
    .paid-user { background: rgba(201,255,61,.1); border-left: 3px solid var(--lime); }
    .pending-user { background: rgba(255,90,60,.1); border-left: 3px solid var(--coral); }
  
    /* Esconder flechitas de number input */
    input[type="number"]::-webkit-outer-spin-button,
    input[type="number"]::-webkit-inner-spin-button {
      -webkit-appearance: none;
      margin: 0;
    }
    input[type="number"] {
      -moz-appearance: textfield;
    }
  </style>
</head>
