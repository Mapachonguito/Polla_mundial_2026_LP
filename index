        html += `</div>`;
      });
      html += `</div></div>`;
      
      html += `<div class="admin-section"><h3>Editar Resultados (${state.matches.length} partidos)</h3><p style="font-size:11px;color:var(--muted);margin-bottom:12px;">Los cambios se guardan automáticamente</p>`;
      state.matches.forEach(m => {
        html += `<div style="display:flex;gap:6px;align-items:center;margin-bottom:8px;padding:8px;background:#0A0D16;border-radius:6px;"><span style="flex:1;font-size:12px;">${m.home} vs ${m.away}</span><input type="number" id="res_h_${m.id}" value="${m.homescore||''}" placeholder="0" onchange="autosaveResult('${m.id}')" style="width:50px;margin:0;"><span>:</span><input type="number" id="res_a_${m.id}" value="${m.awayscore||''}" placeholder="0" onchange="autosaveResult('${m.id}')" style="width:50px;margin:0;"></div>`;
      });
      html += `</div>`;
      
      html += `<div class="admin-section"><h3>🔄 Reiniciar Polla</h3><p style="font-size:11px;color:var(--muted);margin-bottom:12px;">Elimina todos los datos y comienza de nuevo</p>`;
      html += `<button onclick="reiniciarPolla()" style="width:100%;background:#FF5A3C;color:white;padding:12px;font-weight:700;border-radius:6px;border:none;cursor:pointer;">⚠️ REINICIAR POLLA COMPLETA</button>`;
      html += `</div>`;
      
      el.innerHTML = html;

    }

    window.createPool = async function() {
      const poolName = document.getElementById('poolName').value || 'Polla Mundial 2026';
      const adminName = document.getElementById('adminName').value;
      const adminEmail = document.getElementById('adminEmail').value;
      const adminPw = document.getElementById('adminPw').value;
      if(!adminName || !adminEmail || !adminPw) return alert('Llena todos los campos');
      
      // Validar email
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if(!emailRegex.test(adminEmail)) return alert('Por favor ingresa un email válido');
      
      try {
        // Generar usuario a partir del nombre (minúsculas, con espacios permitidos)
        const adminUser = adminName.toLowerCase().trim();
        console.log('1. Admin user generado:', adminUser);
        
        const config = { poolname: poolName, scoring: {exact:5, outcome:3, champion:10, second:5, third:2} };
        console.log('2. Config creado:', config);
        
        // Verificar si ya existe una polla
        const existe = await sb.from('polla_trabajo_config').select('id').eq('id', '1');
        console.log('3. Verificación de config existente:', existe);
        if(existe.data?.length) return alert('⚠️ La polla ya fue creada. No puedes crear otra.');
        
        // Guardar CONFIG en Supabase
        console.log('4. Insertando config...');
        const configResult = await sb.from('polla_trabajo_config').insert([{ id: '1', ...config }]);
        console.log('5. Resultado config:', configResult);
        if(configResult.error) throw new Error('Config: ' + configResult.error.message);
        
        // Guardar USUARIO en Supabase
        const pwHash = hashPw(adminPw);
        console.log('6. Insertando usuario...');
        const userResult = await sb.from('polla_trabajo_users').insert([{ id: adminUser, displayname: adminName, email: adminEmail, pw: pwHash, pwd: adminPw, role: 'admin', paid: false }]);
        console.log('7. Resultado usuario:', userResult);
        if(userResult.error) throw new Error('User: ' + userResult.error.message);
        
        // Insertar PARTIDOS (todos de una vez)
        console.log('8. Insertando 72 partidos...');
        const matchesData = SCHEDULE.map((x, i) => ({ 
          id: 'm' + (i+1), 
          home: x[0], 
          away: x[1], 
          group_name: x[2], 
          datetime: x[3], 
          homescore: '', 
          awayscore: '', 
          finished: false 
        }));
        const matchResult = await sb.from('polla_trabajo_matches').insert(matchesData);
        if(matchResult.error) throw new Error('Matches: ' + matchResult.error.message);
        console.log('9. Partidos insertados:', matchResult.data?.length);
        
        // Actualizar estado local
        state.config = config;
        state.users[adminUser] = { id: adminUser, displayname: adminName, email: adminEmail, pw: pwHash, pwd: adminPw, role: 'admin', paid: false };
        state.matches = SCHEDULE.map((x,i) => ({ id: 'm'+(i+1), home: x[0], away: x[1], group_name: x[2], datetime: x[3], homescore: '', awayscore: '', finished: false }));
