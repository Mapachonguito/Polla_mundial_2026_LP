        if(h !== undefined || a !== undefined || fin !== undefined) {
          m.homescore = h;
          m.awayscore = a;
          m.finished = fin;
          
          await sb.from('polla_trabajo_matches').update({ homescore: h, awayscore: a, finished: fin }).eq('id', m.id);
          saved++;
        }
      }
      
      alert(`✓ Scoring + Podio actualizado · ${saved} resultado(s) guardado(s)`);
      render();
    };

    window.validateNewMatch = function() {
      const home = document.getElementById('new_home')?.value || '';
      const away = document.getElementById('new_away')?.value || '';
      
      if(home && away && home === away) {
        alert('❌ No puedes usar el mismo país en ambos equipos');
        document.getElementById(home === document.getElementById('new_away').value ? 'new_away' : 'new_home').value = '';
      }
    };

    window.addNewMatch = async function() {
      const home = document.getElementById('new_home').value;
      const away = document.getElementById('new_away').value;
      const datetime = document.getElementById('new_datetime').value;
      const phase = document.getElementById('new_phase').value;
      
      if(!home || !away || !datetime) return alert('Llena todos los campos');
      if(home === away) return alert('❌ No puedes usar el mismo país en ambos equipos');
      
      const newId = 'm' + (state.matches.length + 1);
      await sb.from('polla_trabajo_matches').insert([{ 
        id: newId, 
        home, 
        away, 
        group_name: phase, 
        datetime, 
        homescore: '', 
        awayscore: '', 
        finished: false 
      }]);
      
      state.matches.push({ id: newId, home, away, group_name: phase, datetime, homescore: '', awayscore: '', finished: false });
      
      document.getElementById('new_home').value = '';
      document.getElementById('new_away').value = '';
      document.getElementById('new_datetime').value = '';
      document.getElementById('new_phase').value = '';
      
      alert(`✓ Partido agregado: ${home} vs ${away}`);
      render();
