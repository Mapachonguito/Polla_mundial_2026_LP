    window.saveMatch = async function(mid) {
      const m = state.matches.find(x => x.id === mid);
      const h = document.getElementById(`res_h_${mid}`)?.value;
      const a = document.getElementById(`res_a_${mid}`)?.value;
      const fin = document.getElementById(`fin_${mid}`)?.checked;
      
      m.homescore = h;
      m.awayscore = a;
      m.finished = fin;
      
      await sb.from('polla_trabajo_matches').update({ homescore: h, awayscore: a, finished: fin }).eq('id', mid);
      alert('✓ Resultado guardado');
      render();
    };

    init();
  </script>
