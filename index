        state.config = cfg.data?.length ? cfg.data[0] : null;
        (u.data || []).forEach(x => state.users[x.id] = x);
        (m.data || []).forEach(x => state.matches.push(x));
        (p.data || []).forEach(x => state.preds[x.userid + '::' + x.matchid] = { home: x.homescore, away: x.awayscore });
        (pd.data || []).forEach(x => state.podium[x.userid] = { first: x.first, second: x.second, third: x.third });
        
        // Cargar sesión guardada desde localStorage
        const savedUser = localStorage.getItem('polla_user');
